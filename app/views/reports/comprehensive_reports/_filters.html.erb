<%= form_for @comprehensive_report, url: reports_comprehensive_reports_path(@comprehensive_report), html: { class: 'filters-form' } do |f| %>
  <div class="row">
    <div class="columns medium-4">
      <%= f.label :project_id %>
      <%= f.collection_select :project_id, Project.accessible_by(current_ability), :id, :name, include_blank: 'All Projects' %>
    </div>
    <div class="columns medium-4">
      <%= f.label :user_id %>
      <%= f.collection_select :user_id, User.accessible_by(current_ability), :id, :name, include_blank: 'All Employees' %>
    </div>
    <div class="columns medium-2 small-6">
      <%= f.label :start_date , "Start Date" %>
      <%= f.text_field :start_date %>
    </div>
    <div class="columns medium-2 small-6">
      <%= f.label :end_date, "End Date" %>
      <%= f.text_field :end_date %>
    </div>
    <div class="columns medium-2">
      <%= f.submit 'Filter', class: 'button expanded' %>
    </div>
  </div>
<% end %>


